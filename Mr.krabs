Grid.SortOrder = Enum.SortOrder.LayoutOrder

local function CriarBotao(texto, funcaoClique)
	local NovoBotao = Instance.new("TextButton")
	NovoBotao.Parent = ContainerBotoes
	NovoBotao.Text = texto
	NovoBotao.TextColor3 = Color3.fromRGB(255, 255, 255)
	NovoBotao.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	NovoBotao.BackgroundTransparency = 0.15
	NovoBotao.Font = Enum.Font.SourceSansBold
	NovoBotao.TextSize = 14
	NovoBotao.ZIndex = 3
	local BotaoCorner = Instance.new("UICorner")
	BotaoCorner.CornerRadius = UDim.new(0, 6)
	BotaoCorner.Parent = NovoBotao
	NovoBotao.MouseButton1Click:Connect(funcaoClique)
	return NovoBotao
end

local som = Instance.new("Sound")
som.SoundId = ID_AUDIO
som.Volume = 0.8
som.Looped = true
som.Parent = MenuFrame

CriarBotao("🎵 Som", function()
	if som.IsPlaying then som:Stop() else som:Play() end
end)

CriarBotao("💥 Decal", function()
	local function aplicarSpam(objeto)
		for _, filho in pairs(objeto:GetChildren()) do
			if filho:IsA("BasePart") then
				local faces = {Enum.NormalId.Top, Enum.NormalId.Bottom, Enum.NormalId.Left, Enum.NormalId.Right, Enum.NormalId.Front, Enum.NormalId.Back}
				for _, face in pairs(faces) do
					local decal = Instance.new("Decal")
					decal.Texture = ID_IMAGEM
					decal.Face = face
					decal.Parent = filho
				end
			end
			aplicarSpam(filho)
		end
	end
	aplicarSpam(game.Workspace)
end)

CriarBotao("🌌 Skybox", function()
	for _, obj in pairs(Lighting:GetChildren()) do
		if obj:IsA("Sky") then obj:Destroy() end
	end
	local novoCeu = Instance.new("Sky")
	novoCeu.SkyboxBk = ID_IMAGEM
	novoCeu.SkyboxDn = ID_IMAGEM
	novoCeu.SkyboxFt = ID_IMAGEM
	novoCeu.SkyboxLf = ID_IMAGEM
	novoCeu.SkyboxRt = ID_IMAGEM
	novoCeu.SkyboxUp = ID_IMAGEM
	novoCeu.CelestialBodiesShown = false
	novoCeu.Parent = Lighting
end)

CriarBotao("✨ Partículas", function()
	local function prenderParticulas(character)
		local root = character:WaitForChild("HumanoidRootPart", 5)
		if root and not root:FindFirstChild("ImagensEmissao") then
			local emitter = Instance.new("ParticleEmitter")
			emitter.Name = "ImagensEmissao"
			emitter.Texture = ID_IMAGEM
			emitter.Lifetime = NumberRange.new(1.5, 3)
			emitter.Rate = 25
			emitter.Speed = NumberRange.new(5, 10)
			emitter.VelocityInheritance = 0.5
			emitter.SpreadAngle = Vector2.new(45, 45)
			emitter.Size = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 1.5),
				NumberSequenceKeypoint.new(1, 0)
			})
			emitter.Parent = root
		end
	end
	for _, player in pairs(Players:GetPlayers()) do
		if player.Character then prenderParticulas(player.Character) end
		player.CharacterAdded:Connect(prenderParticulas)
	end
end)

CriarBotao("💬 Mensagem", function()
	local function criarAviso(playerGui)
		if playerGui:FindFirstChild("HackedMessageGui") then playerGui.HackedMessageGui:Destroy() end
		local hg = Instance.new("ScreenGui", playerGui)
		hg.Name = "HackedMessageGui"
		
		local faixaPreta = Instance.new("Frame", hg)
		faixaPreta.Size = UDim2.new(1, 0, 0, 50) 
		faixaPreta.Position = UDim2.new(0, 0, 0, 0) 
		faixaPreta.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		faixaPreta.BackgroundTransparency = 0.3 
		faixaPreta.BorderSizePixel = 0
		
		local lbl = Instance.new("TextLabel", faixaPreta)
		lbl.Size = UDim2.new(1, 0, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.Text = "The game was hacked.  by: syperkid43"
		lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
		lbl.Font = Enum.Font.SourceSansBold
		lbl.TextSize = 24
		lbl.TextStrokeTransparency = 0
		lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	end
	for _, p in pairs(Players:GetPlayers()) do
		local pgui = p:FindFirstChild("PlayerGui")
		if pgui then criarAviso(pgui) end
	end
end)
