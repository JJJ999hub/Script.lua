game:GetService("RunService").RenderStepped:Connect(function()
	local tempo = tick() * 3
	local x = math.cos(tempo) * 45
	local y = math.sin(tempo) * 45
	local xOffset = x - 12.5
	local yOffset = y - 12.5
	BolaOrbital.Position = UDim2.new(0.5, xOffset, 0.5, yOffset)
	BolaOrbital.Rotation = tempo * 50 
end)
