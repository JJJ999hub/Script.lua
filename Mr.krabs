local menuAberto = false
local executandoTween = false

local function alternarMenu()
	if executandoTween then return end 
	executandoTween = true
	local infoTween = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	
	if not menuAberto then
		MenuFrame.Position = posicaoBolinha
		MenuFrame.Size = UDim2.new(0, 0, 0, 0)
		local tweenPos = TweenService:Create(MenuFrame, infoTween, {Position = posicaoMenuCentro, BackgroundTransparency = 0})
		local tweenSize = TweenService:Create(MenuFrame, infoTween, {Size = tamanhoMenu})
		tweenPos:Play()
		tweenSize:Play()
		tweenSize.Completed:Connect(function()
			menuAberto = true
			executandoTween = false
		end)
	else
		local tweenPos = TweenService:Create(MenuFrame, infoTween, {Position = posicaoBolinha, BackgroundTransparency = 1})
		local tweenSize = TweenService:Create(MenuFrame, infoTween, {Size = UDim2.new(0, 0, 0, 0)})
		tweenPos:Play()
		tweenSize:Play()
		tweenSize.Completed:Connect(function()
			menuAberto = false
			executandoTween = false
		end)
	end
end

BolaPrincipal.MouseButton1Click:Connect(alternarMenu)

task.spawn(function()
	task.wait(0.2)
	alternarMenu()
end)

local arrastando, posicaoInicial, posJanela
BarraArrastar.InputBegan:Connect(function(input)
	if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and menuAberto then
		arrastando = true
		posicaoInicial = input.Position
		posJanela = MenuFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then arrastando = false end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if arrastando and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - posicaoInicial
		local novaPos = UDim2.new(posJanela.X.Scale, posJanela.X.Offset + delta.X, posJanela.Y.Scale, posJanela.Y.Offset + delta.Y)
		MenuFrame.Position = novaPos
		posicaoMenuCentro = novaPos 
	end
end)

